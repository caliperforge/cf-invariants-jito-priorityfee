target/
step0_resolve.log
step1_build_sbf.log
*.log
.DS_Store
Cargo.lock.bak

# Crucible fuzz corpus/output — generated by `crucible run`, not source.
# These are reproduced by CI on every run; never check them in (the
# crashes/ trees blew the tracked-file count to ~50k pre-cleanup on
# the cf-invariants-jito-priorityfee tree; same pattern as the sibling
# cf-invariants-jito / cf-invariants-jito-tippayment repos).
crashes/
corpus/
ci-out/

# Upstream-repo .github trees inside vendored references/ — we run our
# own CI from the repo-root .github/workflows/ only.
references/*/.github/

# Local Crucible captures (clean.out / planted.out) — they embed the
# operator's absolute filesystem paths and ~MB of upstream Crucible
# build noise. The CI workflow regenerates clean, ANSI-stripped
# scorecards under findings/<inv>_<variant>/scorecard.md on every run
# and uploads them as the artifact-of-record. Don't ship the local
# scratch.
findings/
